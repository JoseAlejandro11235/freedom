APP_NAME=Freedom
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# Use the same host:port you open in the browser (Docker default: 8888).
APP_URL=http://localhost:8888

# Filament back-office path (no leading slash). Example: http://localhost:8888/admin-backoffice-free-dom
FILAMENT_ADMIN_PATH=admin-backoffice-free-dom

# First admin (used by db:seed). Create more with: php artisan freedom:make-admin you@example.com
ADMIN_EMAIL=admin@freedom.test

# Docker: compose sets APP_URL/ASSET_URL to http://localhost:8888 automatically.
# Open http://localhost:8888 after: docker compose up -d
# Dev (no rebuild per change): see DEV.md — docker-compose.dev.yml + npm run dev
# If UI is dark/frozen: npm run dev:stop (stale public/hot without Vite running)
# APP_PORT=8888
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=freedom
# DB_USERNAME=freedom
# DB_PASSWORD=secret

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
# Livewire temp uploads must stay on a local disk (not s3), or admin image uploads hang.
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# MinIO (S3-compatible) — Docker: http://localhost:9001 console, API :9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=freedom
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/freedom
BRAND_LOGO_PATH=freedom.png
# Optional square favicon in MinIO (e.g. favicon.png). Leave empty to use public/favicon.svg.
# BRAND_FAVICON_PATH=favicon.png

VITE_APP_NAME="${APP_NAME}"
